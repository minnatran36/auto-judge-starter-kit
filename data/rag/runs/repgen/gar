www.aljazeera.net/health/2024/4/16/%D8%AA%D8%B9%D8%B1%D9%81-%D8%B9%D9%84%D9%89-%D8%B1%D9%8A%D8%A7%D8%B6%D8%A9-%D8%AA%D8%A7%D9%8A-%D8%AA%D8%B4%D9%8A","warc_date":"2024-04-16T18:28:32.000Z","warc_filename":"<urn:uuid:2e864b6f-2e85-4876-845a-6831478b1237>","warc_url":"https://www.aljazeera.net/health/2024/4/16/%D8%AA%D8%B9%D8%B1%D9%81-%D8%B9%D9%84%D9%89-%D8%B1%D9%8A%D8%A7%D8%B6%D8%A9-%D8%AA%D8%A7%D9%8A-%D8%AA%D8%B4%D9%8A?traffic_source=rss"},"created":"2024-04-16T18:55:44.000Z","lang":"eng"}}}
