here.", "citations": {"44424d28-dcbb-4e8d-b7d3-46eee5796966_522924419": 100.0}}], "references": ["fb162a3d-7d4f-4669-83a6-c3edb226ea03_963699828", "d0fdd296-9dbe-4774-a00b-b9fe01772cb1_668789018", "f59dc840-8a51-49ca-a687-2f0a97d918ca_227922426", "44424d28-dcbb-4e8d-b7d3-46eee5796966_522924419", "13ea93b3-b90a-433c-83f5-d01dbdf2cf08_453229130"]}
